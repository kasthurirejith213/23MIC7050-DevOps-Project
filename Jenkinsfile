pipeline {
    agent any

    stages {

        stage('Clone') {
            steps {
                echo 'Repository cloned successfully.'
            }
        }

        stage('Build') {
            steps {
                echo 'Building Corporate Website...'
            }
        }

        stage('Test') {
            steps {
                echo 'Testing website...'
            }
        }

        stage('Deploy') {
            steps {
                echo 'Deployment Successful.'
            }
        }
    }
}